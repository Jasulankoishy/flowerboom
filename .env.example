# Server configuration
PORT=3003
HOST=0.0.0.0
NODE_ENV=development

# Database (Supabase Postgres)
DATABASE_URL="postgresql://postgres.project-ref:password@aws-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.project-ref:password@aws-region.pooler.supabase.com:5432/postgres"

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Backend URL (for OAuth callbacks)
BACKEND_URL=http://localhost:3003

# JWT Secrets (GENERATE NEW RANDOM STRINGS!)
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars

# Admin credentials (CHANGE IMMEDIATELY!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-password-here

# Google OAuth (Get from: https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email configuration (Resend)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com

# API URL for frontend
VITE_API_URL=http://localhost:3003

# ⚠️ SECURITY CHECKLIST:
# [ ] Generate new JWT_SECRET (min 32 chars)
# [ ] Generate new JWT_REFRESH_SECRET (min 32 chars)
# [ ] Change ADMIN_PASSWORD to strong password
# [ ] Get GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET from Google Console
# [ ] Get new RESEND_API_KEY from dashboard
# [ ] Update EMAIL_FROM to your verified domain
# [ ] NEVER commit .env to Git (check .gitignore)
